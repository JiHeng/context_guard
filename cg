def cmd_rules(args: list[str]) -> None:
    """Manage detection rules. No args = interactive; with args = direct command."""
    if not args:
        _interactive_rules()
        return

    sub = args[0]
    if sub == "list":
        _rules_list_noninteractive()
    elif sub == "enable" and len(args) >= 2:
        _rules_enable(args[1])
    elif sub == "disable" and len(args) >= 2:
        _rules_disable(args[1])
    elif sub == "allow" and len(args) >= 2:
        _rules_allow(args[1])
    elif sub == "deny" and len(args) >= 2:
        _rules_deny(args[1])
    elif sub == "add" and len(args) >= 3 and args[1] == "keyword":
        sev = args[3] if len(args) >= 4 else "sensitive"
        _rules_add_keyword(args[2], sev)
    elif sub == "remove" and len(args) >= 3 and args[1] == "keyword":
        _rules_remove_keyword(args[2])
    elif sub == "add" and len(args) >= 4 and args[1] == "pattern":
        sev = args[4] if len(args) >= 5 else "sensitive"
        _rules_add_pattern(args[2], args[3], sev)
    elif sub == "remove" and len(args) >= 3 and args[1] == "pattern":
        _rules_remove_pattern(args[2])
    else:
        print("Usage: cg rules [list|enable|disable|allow|deny|add|remove]")
        sys.exit(1)


# ── block / unblock / list ────────────────────────────────────────────

def _is_known_rule(name: str) -> bool:
    """Check if name is a base or catalog rule."""
    base_cats = {cat for cat, _ in _get_base_rules()}
    catalog = _get_catalog_rules()
    return name in base_cats or name in catalog


def cmd_block(args: list[str]) -> None:
    """Block (redact) something: a rule, keyword, regex, or deny an allowlisted value."""
    if not args:
        print("Usage: cg block <rule|keyword <kw>|regex <pattern>|value>")
        sys.exit(1)

    sub = args[0]

    # cg block keyword "X"
    if sub == "keyword" and len(args) >= 2:
        sev = args[2] if len(args) >= 3 else "sensitive"
        _rules_add_keyword(args[1], sev)
        return

    # cg block regex "pattern"
    if sub == "regex" and len(args) >= 2:
        pattern = args[1]
        sev = args[2] if len(args) >= 3 else "sensitive"
        category = "custom_regex"
        _rules_add_pattern(category, pattern, sev)
        return

    # Bare argument: disambiguation
    name = sub

    # 1. Known rule name → enable
    if _is_known_rule(name):
        _rules_enable(name)
        return

    # 2. In allowlist → remove from allowlist (deny)
    entries = _load_allow_entries()
    if name in entries:
        _rules_deny(name)
        return

    # 3. Otherwise → error with hint
    print(f'✗ unknown rule: {name}. Did you mean `cg block keyword "{name}"`?')
    sys.exit(1)


def cmd_unblock(args: list[str]) -> None:
    """Unblock (stop redacting) something: a rule, keyword, regex, or allowlist a value."""
    if not args:
        print("Usage: cg unblock <rule|keyword <kw>|regex <pattern>|value>")
        sys.exit(1)

    sub = args[0]

    # cg unblock keyword "X"
    if sub == "keyword" and len(args) >= 2:
        _rules_remove_keyword(args[1])
        return

    # cg unblock regex "pattern"
    if sub == "regex" and len(args) >= 2:
        _rules_remove_pattern_by_regex(args[1])
        return

    # Bare argument: disambiguation
    name = sub

    # 1. Known rule name → disable
    if _is_known_rule(name):
        _rules_disable(name)
        return

    # 2. Already in allowlist → tell user
    entries = _load_allow_entries()
    if name in entries:
        print(f"  already in allowlist: {name}")
        return

    # 3. Otherwise → add to allowlist
    _rules_allow(name)


def cmd_list(_args: list[str]) -> None:
    """Show all rules."""
    _rules_list_noninteractive()


_COMMANDS = {
    "start": cmd_start,
    "stop": cmd_stop,
    "pause": cmd_pause,
    "resume": cmd_resume,
    "status": cmd_status,
    "update": cmd_update,
    "uninstall": cmd_uninstall,
}

_COMMANDS_WITH_ARGS = {
    "_acquire": cmd_acquire,
    "_release": cmd_release,
    "rules": cmd_rules,
    "block": cmd_block,
    "unblock": cmd_unblock,
    "list": cmd_list,
}


def main() -> None:
    if len(sys.argv) < 2:
        print(__doc__)
        sys.exit(1)
    cmd_name = sys.argv[1]
    if cmd_name in _COMMANDS:
        _COMMANDS[cmd_name]()
    elif cmd_name in _COMMANDS_WITH_ARGS:
        _COMMANDS_WITH_ARGS[cmd_name](sys.argv[2:])
    else:
        print(__doc__)
        sys.exit(1)


if __name__ == "__main__":
    main()
